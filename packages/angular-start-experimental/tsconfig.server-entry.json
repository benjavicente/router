{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ES2022",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "rootDir": "./src",
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@benjavicente/angular-start-experimental/server": ["./src/server.ts"]
    }
  },
  "include": ["src/default-entry/server.ts"]
}
