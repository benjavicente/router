{
  "name": "root",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TanStack/router.git"
  },
  "packageManager": "pnpm@10.28.0",
  "type": "module",
  "scripts": {
    "cleanNodeModules": "pnpm -r exec rm -rf node_modules",
    "clean": "pnpm --filter \"./packages/**\" run clean",
    "test": "pnpm run test:ci",
    "test:pr": "nx affected --targets=test:eslint,test:unit,test:e2e,test:types,test:build,build",
    "test:ci": "nx run-many --targets=test:eslint,test:unit,test:e2e,test:types,test:build,build",
    "test:eslint": "nx affected --target=test:eslint --exclude=examples/**,e2e/**",
    "test:unit": "nx affected --target=test:unit --exclude=examples/**,e2e/**",
    "test:unit:dev": "pnpm run test:unit && nx watch --all -- pnpm run test:unit",
    "test:build": "nx affected --target=test:build --exclude=examples/**",
    "test:types": "nx affected --target=test:types --exclude=examples/**",
    "test:e2e": "nx run-many --target=test:e2e",
    "benchmark:bundle-size": "pnpm nx run @benchmarks/bundle-size:build",
    "benchmark:client-nav": "pnpm nx run @benchmarks/client-nav:test:perf",
    "benchmark:ssr": "pnpm nx run @benchmarks/ssr:test:perf",
    "build": "nx affected --target=build --exclude=e2e/** --exclude=examples/**",
    "build:all": "nx run-many --target=build --exclude=examples/** --exclude=e2e/**",
    "watch": "pnpm run build:all && nx watch --all -- pnpm run build:all",
    "dev": "pnpm run watch",
    "format": "prettier --experimental-cli --ignore-unknown '**/*' --write",
    "changeset": "changeset",
    "changeset:publish": "changeset publish",
    "changeset:version": "changeset version && node scripts/update-example-deps.mjs && pnpm install --no-frozen-lockfile && pnpm format",
    "gpt-generate": "node gpt/generate.js",
    "set-ts-version": "node scripts/set-ts-version.js",
    "labeler-generate": "node scripts/generate-labeler-config.ts",
    "cleanup-empty-packages": "node scripts/cleanup-empty-packages.mjs",
    "test:docs": "node scripts/verify-links.ts",
    "vite-ecosystem-ci:build": "nx run-many --targets=build --projects=@benjavicente/router-plugin,@benjavicente/start-plugin-core,@benjavicente/react-start,@benjavicente/react-start-client,@benjavicente/react-start-server --skipRemoteCache",
    "vite-ecosystem-ci:before-test": "pnpm exec playwright install chromium",
    "vite-ecosystem-ci:test": "nx run-many --targets=test:unit --projects=@benjavicente/router-plugin,@benjavicente/start-plugin-core,@benjavicente/react-start-client --skipRemoteCache && nx run-many --target=test:e2e --projects=tanstack-router-e2e-react-basic-file-based,tanstack-router-e2e-react-basic-file-based-code-splitting,tanstack-react-start-e2e-basic,tanstack-react-start-e2e-basic-spa,tanstack-react-start-e2e-basic-prerender,tanstack-react-start-e2e-basic-preview,tanstack-vue-start-e2e-basic,tanstack-vue-start-e2e-basic-spa,tanstack-vue-start-e2e-basic-prerender,tanstack-vue-start-e2e-basic-preview,tanstack-solid-start-e2e-basic,tanstack-solid-start-e2e-basic-spa,tanstack-solid-start-e2e-basic-prerender,tanstack-solid-start-e2e-basic-preview --skipRemoteCache"
  },
  "nx": {
    "includedScripts": [
      "test:docs"
    ]
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/cli": "^2.30.0",
    "@eslint-react/eslint-plugin": "^1.26.2",
    "@playwright/test": "^1.57.0",
    "@svitejs/changesets-changelog-github-compact": "^1.2.0",
    "@tanstack/eslint-config": "0.4.0",
    "@tanstack/query-core": "^5.90.19",
    "@tanstack/react-query": "^5.90.19",
    "@tanstack/vite-config": "0.5.2",
    "@types/node": "25.0.9",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jsdom": "^25.0.1",
    "markdown-link-extractor": "^4.0.3",
    "nx": "22.5.1",
    "prettier": "^3.8.0",
    "publint": "^0.3.16",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "redaxios": "^0.5.1",
    "rimraf": "^6.1.2",
    "tinyglobby": "^0.2.15",
    "typescript": "^6.0.2",
    "typescript55": "npm:typescript@5.5",
    "typescript56": "npm:typescript@5.6",
    "typescript57": "npm:typescript@5.7",
    "typescript58": "npm:typescript@5.8",
    "typescript59": "npm:typescript@5.9",
    "vite": "^8.0.0",
    "vitest": "^4.0.17"
  },
  "pnpm": {
    "overrides": {
      "@types/babel__traverse": "^7.28.0",
      "vite-plugin-dts": "4.2.3",
      "solid-js": "1.9.10",
      "react": "$react",
      "react-dom": "$react-dom",
      "@types/react": "$@types/react",
      "@types/react-dom": "$@types/react-dom",
      "eslint": "$eslint",
      "vite": "$vite",
      "@types/node": "$@types/node",
      "@playwright/test": "$@playwright/test",
      "@tanstack/react-query": "$@tanstack/react-query",
      "@tanstack/query-core": "$@tanstack/query-core",
      "@benjavicente/history": "workspace:*",
      "@benjavicente/router-core": "workspace:*",
      "@benjavicente/react-router": "workspace:*",
      "@benjavicente/router-cli": "workspace:*",
      "@benjavicente/router-devtools": "workspace:*",
      "@benjavicente/router-devtools-core": "workspace:^",
      "@benjavicente/react-router-devtools": "workspace:^",
      "@benjavicente/solid-router-devtools": "workspace:^",
      "@benjavicente/router-generator": "workspace:*",
      "@benjavicente/virtual-file-routes": "workspace:*",
      "@benjavicente/router-plugin": "workspace:*",
      "@benjavicente/router-vite-plugin": "workspace:*",
      "@benjavicente/router-ssr-query-core": "workspace:*",
      "@benjavicente/react-router-ssr-query": "workspace:*",
      "@benjavicente/solid-router-ssr-query": "workspace:*",
      "@benjavicente/vue-router-ssr-query": "workspace:*",
      "@benjavicente/zod-adapter": "workspace:*",
      "@benjavicente/valibot-adapter": "workspace:*",
      "@benjavicente/arktype-adapter": "workspace:*",
      "@benjavicente/react-start": "workspace:*",
      "@benjavicente/react-start-client": "workspace:*",
      "@benjavicente/react-start-server": "workspace:*",
      "@benjavicente/solid-start": "workspace:*",
      "@benjavicente/solid-start-client": "workspace:*",
      "@benjavicente/solid-start-server": "workspace:*",
      "@benjavicente/angular-start-experimental": "workspace:*",
      "@benjavicente/angular-start-experimental-client": "workspace:*",
      "@benjavicente/angular-start-experimental-server": "workspace:*",
      "@benjavicente/vue-start": "workspace:*",
      "@benjavicente/vue-start-client": "workspace:*",
      "@benjavicente/vue-start-server": "workspace:*",
      "@benjavicente/start-plugin-core": "workspace:*",
      "@benjavicente/start-client-core": "workspace:*",
      "@benjavicente/start-server-core": "workspace:*",
      "@benjavicente/start-storage-context": "workspace:*",
      "@benjavicente/vue-router": "workspace:*",
      "@benjavicente/vue-router-devtools": "workspace:*",
      "@benjavicente/eslint-plugin-router": "workspace:*",
      "@benjavicente/router-utils": "workspace:*",
      "@benjavicente/start-static-server-functions": "workspace:*",
      "@benjavicente/nitro-v2-vite-plugin": "workspace:*"
    }
  }
}
